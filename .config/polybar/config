[colors]

background = ${xrdb:color0:#222}
color1 = ${xrdb:color2}
color2 = ${xrdb:color11}
color3 = ${xrdb:color14}

;  _                    
; | |__   __ _ _ __ ___ 
; | '_ \ / _` | '__/ __|
; | |_) | (_| | |  \__ \
; |_.__/ \__,_|_|  |___/

[bar/base]
font-0=mononoki Nerd Font:size=11:antialias=true;3
font-1=FontAwesome5Free:style=Regular:size=9:antialias=true;3
font-2=FontAwesome5Free:style=Solid:size=9:antialias=true;3
font-3=IPAGothic:style=Regular:size=11:antialias=true;3


height = 35
radius = 0
;Works very well with a ;radius like this! Put it on every bar.

background = ${colors.background}
override-redirect=true
offset-y = 15

wm-restack = bspwm

[bar/bspwm]
inherit = bar/base
width = 27%
foreground = ${colors.color1}
offset-x = 25
modules-left = bspwm xwindow


[bar/bspwm-ex]
inherit = bar/bspwm
monitor = HDMI2
width = 25%
offset-x = 25


[bar/stats]
inherit = bar/base
width = 13.2%
foreground = ${colors.color1}
offset-x = 67.8%
modules-left = battery cpu temperature 

[bar/stats-ex]
inherit = bar/stats
monitor = HDMI2
width = 11.2%
foreground = ${colors.color1}
offset-x = 72.7%
modules-left = battery cpu temperature 


[bar/tray]
inherit = bar/base
width = 15.8%
padding-right = 0
offset-x = 82.6%
modules-left = pulseaudio time power

[bar/tray-ex]
inherit = bar/tray
monitor = HDMI2
width = 13.5%
offset-x = 85.2%

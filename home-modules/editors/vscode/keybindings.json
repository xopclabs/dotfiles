[
    // ================================================================
    // UNIVERSAL LEADER = F1
    //
    // One coherent rule, like Super in Hyprland: F1 then a key, and it
    // fires the same in the editor (any vim mode), the terminal, and the
    // AI chat textbox. No Esc-to-normal-mode required, no shell clashes.
    //
    //   Direction (neio = left/down/up/right) -> focus panes
    //   d = close/kill            s/h = split (side/down, tmux-style)
    //   f = fuzzy open any file   / = search in files
    //   b = sidebar   t = terminal   q = command palette
    //   a = AI group  c = code   g = goto/git   r = run/debug   w = move
    // ================================================================
    {
        "command": "-workbench.action.showCommands",
        "key": "f1"
    },
    {
        "command": "workbench.action.showCommands",
        "key": "f1 q"
    },

    // ---- Pane focus (works in every context) -----------------------
    {
        "command": "workbench.action.navigateLeft",
        "key": "f1 n"
    },
    {
        "command": "workbench.action.navigateDown",
        "key": "f1 e"
    },
    {
        "command": "workbench.action.navigateUp",
        "key": "f1 i"
    },
    {
        "command": "workbench.action.navigateRight",
        "key": "f1 o"
    },
    // Guaranteed exits: leave chat to the left, leave terminal upward,
    // even when the spatial navigate* command would no-op.
    {
        "command": "workbench.action.focusActiveEditorGroup",
        "key": "f1 n",
        "when": "composerFocused || focusedView =~ /^workbench.panel.aichat.view/"
    },
    {
        "command": "workbench.action.focusActiveEditorGroup",
        "key": "f1 i",
        "when": "terminalFocus"
    },

    // ---- AI chat / agent (F1 a ...) --------------------------------
    // Focus toggle: into chat, or back to the editor if already there.
    {
        "command": "composer.focusComposer",
        "key": "f1 a s",
        "when": "!composerFocused && !(focusedView =~ /^workbench.panel.aichat.view/)"
    },
    {
        "command": "workbench.action.focusActiveEditorGroup",
        "key": "f1 a s",
        "when": "composerFocused || focusedView =~ /^workbench.panel.aichat.view/"
    },
    {
        "command": "composer.newAgentChat",
        "key": "f1 a n"
    },
    {
        "command": "aichat.newchataction",
        "key": "f1 a q"
    },
    {
        "command": "composer.startComposerPromptFromSelection",
        "key": "f1 a a",
        "when": "editorTextFocus"
    },
    {
        "command": "aipopup.action.modal.generate",
        "key": "f1 a e",
        "when": "editorTextFocus"
    },
    {
        "command": "composer.acceptComposerStep",
        "key": "f1 a y"
    },
    {
        "command": "composer.cancelComposerStep",
        "key": "f1 a d"
    },

    // ---- Tabs / splits / editor movement ---------------------------
    {
        "command": "workbench.action.closeActiveEditor",
        "key": "f1 d"
    },
    {
        "command": "workbench.action.previousEditorInGroup",
        "key": "f1 comma"
    },
    {
        "command": "workbench.action.nextEditorInGroup",
        "key": "f1 dot"
    },
    {
        "command": "workbench.action.splitEditor",
        "key": "f1 s"
    },
    {
        "command": "workbench.action.splitEditorDown",
        "key": "f1 h"
    },
    {
        "command": "workbench.action.moveEditorToLeftGroup",
        "key": "f1 w n"
    },
    {
        "command": "workbench.action.moveEditorToBelowGroup",
        "key": "f1 w e"
    },
    {
        "command": "workbench.action.moveEditorToAboveGroup",
        "key": "f1 w i"
    },
    {
        "command": "workbench.action.moveEditorToRightGroup",
        "key": "f1 w o"
    },

    // ---- Files / search / workbench toggles ------------------------
    {
        "command": "workbench.action.quickOpen",
        "key": "f1 f"
    },
    {
        "command": "workbench.action.findInFiles",
        "key": "f1 slash"
    },
    {
        "command": "workbench.action.terminal.toggleTerminal",
        "key": "f1 t"
    },
    {
        "args": {
            "commands": [
                "workbench.action.toggleSidebarVisibility",
                "workbench.files.action.focusFilesExplorer"
            ]
        },
        "command": "runCommands",
        "key": "f1 b",
        "when": "!sideBarFocus"
    },
    {
        "args": {
            "commands": [
                "workbench.action.toggleSidebarVisibility",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "command": "runCommands",
        "key": "f1 b",
        "when": "sideBarFocus"
    },
    {
        "command": "workbench.view.scm",
        "key": "f1 g g"
    },

    // ---- Code (F1 c ...) -------------------------------------------
    {
        "command": "editor.action.codeAction",
        "key": "f1 c a",
        "when": "editorTextFocus"
    },
    {
        "command": "editor.action.rename",
        "key": "f1 c r",
        "when": "editorTextFocus"
    },
    {
        "command": "workbench.action.gotoSymbol",
        "key": "f1 c s",
        "when": "editorTextFocus"
    },

    // ---- Goto (F1 g ...) -------------------------------------------
    {
        "command": "editor.action.revealDefinition",
        "key": "f1 g d",
        "when": "editorTextFocus"
    },
    {
        "command": "editor.action.goToReferences",
        "key": "f1 g r",
        "when": "editorTextFocus"
    },

    // ---- Run / debug (F1 r ...) ------------------------------------
    {
        "command": "workbench.action.debug.selectandstart",
        "key": "f1 r a",
        "when": "debuggersAvailable"
    },
    {
        "command": "workbench.action.debug.stop",
        "key": "f1 r t",
        "when": "inDebugMode && !focusedSessionIsAttached"
    },
    {
        "command": "workbench.action.debug.stepOver",
        "key": "f1 r o",
        "when": "inDebugMode && debugState == 'stopped'"
    },
    {
        "command": "editor.debug.action.toggleBreakpoint",
        "key": "f1 r b",
        "when": "editorTextFocus"
    },
    {
        "command": "editor.debug.action.showDebugHover",
        "key": "f1 r e",
        "when": "editorTextFocus && inDebugMode && debugState == 'stopped'"
    },
    {
        "command": "workbench.action.debug.continue",
        "key": "f1 r c",
        "when": "inDebugMode && debugState == 'stopped'"
    },

    // ================================================================
    // Editor vim niceties (not leader-based)
    // ================================================================
    {
        "command": "editor.action.moveLinesUpAction",
        "key": "shift-k",
        "when": "vim.mode == 'VisualLine' && editorTextFocus"
    },
    {
        "command": "editor.action.moveLinesDownAction",
        "key": "shift-j",
        "when": "vim.mode == 'VisualLine' && editorTextFocus"
    },
    {
        "command": "editor.action.showHover",
        "key": "shift-k",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },

    // ================================================================
    // Vim-everywhere: home-row navigation in non-editor surfaces.
    // Rule: e/i = down/up where you are NOT typing,
    //       ctrl+e/ctrl+i where an input is focused.
    // ================================================================

    // Generic lists / trees (sidebar, search results, etc.)
    {
        "command": "list.focusDown",
        "key": "e",
        "when": "listFocus && !inputFocus"
    },
    {
        "command": "list.focusUp",
        "key": "i",
        "when": "listFocus && !inputFocus"
    },
    {
        "command": "list.expand",
        "key": "o",
        "when": "listFocus && !inputFocus"
    },
    {
        "command": "list.collapse",
        "key": "n",
        "when": "listFocus && !inputFocus"
    },

    // Quick open / quick input (you ARE typing -> ctrl+e/ctrl+i)
    {
        "command": "workbench.action.quickOpenSelectNext",
        "key": "ctrl+e",
        "when": "inQuickOpen"
    },
    {
        "command": "workbench.action.quickOpenSelectPrevious",
        "key": "ctrl+i",
        "when": "inQuickOpen"
    },

    // References peek widget
    {
        "command": "goToNextReference",
        "key": "e",
        "when": "referenceSearchVisible && !inputFocus"
    },
    {
        "command": "goToPreviousReference",
        "key": "i",
        "when": "referenceSearchVisible && !inputFocus"
    },

    // Notification toasts
    {
        "command": "notifications.focusNextToast",
        "key": "e",
        "when": "notificationFocus"
    },
    {
        "command": "notifications.focusPreviousToast",
        "key": "i",
        "when": "notificationFocus"
    },
    {
        "command": "notification.clear",
        "key": "d",
        "when": "notificationFocus"
    },

    // ================================================================
    // File explorer (vim-like single-key operations)
    // ================================================================
    {
        "command": "renameFile",
        "key": "r",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "filesExplorer.copy",
        "key": "c",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "filesExplorer.paste",
        "key": "p",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "filesExplorer.cut",
        "key": "x",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "deleteFile",
        "key": "d",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "explorer.newFile",
        "key": "a",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "explorer.openToSide",
        "key": "s",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "args": {
            "commands": [
                "workbench.action.splitEditorDown",
                "explorer.openAndPassFocus",
                "workbench.action.closeOtherEditors"
            ]
        },
        "command": "runCommands",
        "key": "shift-s",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "command": "explorer.openAndPassFocus",
        "key": "enter",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceIsFolder && !inputFocus"
    },
    {
        "command": "list.toggleExpand",
        "key": "enter",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && explorerResourceIsFolder && !inputFocus"
    },

    // ================================================================
    // Cursor default-binding cleanup (preserved from prior config)
    // ================================================================
    {
        "command": "-aichat.newchataction",
        "key": "ctrl+l"
    },
    {
        "key": "ctrl+shift+backspace",
        "command": "-composer.cancelComposerStep",
        "when": "composerFocused || focusedView =~ /^workbench.panel.aichat.view/"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },
    {
        "key": "ctrl+shift+[Backslash]",
        "command": "-editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    }
]
